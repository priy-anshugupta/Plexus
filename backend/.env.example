# =============================================================================
# Plexus Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before running the application.
# Do NOT commit the .env file to version control.

# --- Application ---
APP_NAME=Plexus
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# --- Database: PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=plexus
POSTGRES_PASSWORD=plexuspassword
POSTGRES_DB=plexus_db

# --- Database: Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=plexuspassword

# --- Database: Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Database: Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- LLM Providers ---
OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- GitHub App (for Auto-Fix PRs) ---
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=
# GITHUB_WEBHOOK_SECRET=
